{
  "expo": {
    "name": "FGEHA-RSP",
    "slug": "fgeha-app",
    "version": "1.1.1",
    "orientation": "default",
    "icon": "./assets/logo.png",
    "scheme": "fgeha",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fgeha.app",
      "buildNumber": "1"
    },
    "android": {
      "versionCode": 12,
      "resizableActivity": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.fgeha.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-notifications",
      "expo-local-authentication",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          },
          "ios": {
            "infoPlist": {
              "NSAppTransportSecurity": { "NSAllowsArbitraryLoads": true },
              "NSFaceIDUsageDescription": "Use Face ID to securely sign in to your account.",
              "NSLocationWhenInUseUsageDescription": "Allow location access to attach your current location to service requests.",
              "NSPhotoLibraryUsageDescription": "Allow photo library access to upload profile, ID card, and issue photos.",
              "NSUserNotificationUsageDescription": "Allow notifications to receive updates and alerts about your requests."
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "storeUrls": {
        "android": "https://play.google.com/store/apps/details?id=com.fgeha.app",
        "ios": "https://apps.apple.com/app/idYOUR_APP_ID"
      },
      "eas": {
        "projectId": "b97876b9-6365-49af-99b6-ec0c012f9c78"
      }
    }
  }
}
